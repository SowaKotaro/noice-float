---
import { getCollection } from "astro:content";
import MeaningCards from "../components/MeaningCards";
import SiteLogo from "../components/SiteLogo.astro";
import Layout from "../layouts/Layout.astro";
import { TAGS } from "../lib/tags";

const words = (await getCollection("words")).sort((a, b) =>
  a.data.reading.localeCompare(b.data.reading, "ja"),
);
---

<Layout title="そのフロート、アイス乗ってません！">
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-8">
    <header class="mb-8">
      <h1 class="mb-3">
        <SiteLogo class="h-auto w-full" />
      </h1>
      <p class="font-bold text-black">
        エンジニアと非エンジニアで意味の違う語を、両方の視点から引ける辞書。
      </p>
    </header>

    {/* 一覧は操作なしの静的プレビュー。カード全体が語ページへのリンク。
        前面は語ページと同じ ENGINEER 側で揃えてある。 */}
    <ul class="flex flex-wrap justify-center gap-x-14 gap-y-10">
      {
        words.map((word) => (
          <li class="w-[320px] sm:w-[560px]">
            <MeaningCards
              href={`/words/${word.id}`}
              term={word.data.term}
              reading={word.data.reading}
              engineer={word.data.engineer}
              general={word.data.general}
            />
            {word.data.tags.length > 0 && (
              <ul class="mt-12 flex flex-wrap gap-2">
                {word.data.tags.map((tag) => (
                  <li
                    title={TAGS[tag].description}
                    class:list={[
                      "border-2 border-black px-2 py-0.5 text-xs font-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]",
                      TAGS[tag].world === "tech"
                        ? "bg-[#4ECDC4]"
                        : "bg-[#FFD166]",
                    ]}
                  >
                    #{tag}
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</Layout>

---
import { getCollection } from "astro:content";
import SiteLogo from "../components/SiteLogo.astro";
import Layout from "../layouts/Layout.astro";
import { TAGS } from "../lib/tags";

const words = (await getCollection("words")).sort((a, b) =>
  a.data.reading.localeCompare(b.data.reading, "ja"),
);
---

<Layout title="そのフロート、アイス乗ってません！">
  <div class="mx-auto max-w-3xl px-4 py-10">
    <header class="mb-10">
      <h1 class="mb-3">
        <SiteLogo class="h-auto w-full" />
      </h1>
      <p class="text-muted-foreground font-bold">
        エンジニアと非エンジニアで意味の違う語を、両方の視点から引ける辞書。
      </p>
    </header>

    <ul class="space-y-6">
      {
        words.map((word) => (
          <li class="bg-card border-4 shadow-lg">
            <a href={`/words/${word.id}`} class="block p-5">
              <div class="mb-3 flex flex-wrap items-baseline gap-x-3 gap-y-2">
                <h2 class="font-head text-2xl font-black">{word.data.term}</h2>
                {word.data.tags.length > 0 && (
                  <ul class="flex flex-wrap gap-1.5">
                    {word.data.tags.map((tag) => (
                      <li
                        class:list={[
                          "border-2 px-2 py-0.5 text-xs font-black",
                          TAGS[tag].world === "tech"
                            ? "bg-engineer"
                            : "bg-general",
                        ]}
                      >
                        #{tag}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
              {/* 重なった書類風のプレビュー。2 枚とも本文を持つ完全なカードで、
                  前面=エンジニア（しっかり相当）、背面=ふつうがずれてのぞく。
                  操作は詳細ページで。 */}
              <div class="relative grid pr-4 pb-6">
                <div
                  class="bg-general col-start-1 row-start-1 z-10 translate-x-4 translate-y-6 rotate-[2.4deg] scale-[0.97] border-2 p-4 shadow-md"
                >
                  <p class="mb-1 text-xs font-black">ふつう</p>
                  <p class="text-sm leading-relaxed">
                    {word.data.general.meaning}
                  </p>
                </div>
                <div
                  class="bg-engineer col-start-1 row-start-1 z-20 rotate-[-1.2deg] border-2 p-4 shadow-md"
                >
                  <p class="mb-1 text-xs font-black">エンジニア</p>
                  <p class="text-sm leading-relaxed">
                    {word.data.engineer.levels[1]}
                  </p>
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Layout>

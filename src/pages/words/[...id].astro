---
import { getCollection, render } from "astro:content";
import MeaningCards from "../../components/MeaningCards";
import SiteLogo from "../../components/SiteLogo.astro";
import Layout from "../../layouts/Layout.astro";
import { TAGS } from "../../lib/tags";

export async function getStaticPaths() {
  const words = await getCollection("words");
  return words.map((word) => ({ params: { id: word.id }, props: { word } }));
}

const { word } = Astro.props;
const { Content } = await render(word);
const hasBody = !!word.body?.trim();
---

<Layout title={`${word.data.term} - そのフロート、アイス乗ってません！`}>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <a href="/" class="mb-8 inline-block" title="一覧へ">
      <SiteLogo
        widths={[240, 480]}
        sizes="240px"
        class="h-auto w-[180px] sm:w-[240px]"
      />
    </a>

    <h1 class="font-head mb-2 text-4xl font-black">{word.data.term}</h1>
    <p class="text-muted-foreground mb-6 font-bold">{word.data.reading}</p>

    <div class="mb-8">
      <MeaningCards
        client:load
        engineer={word.data.engineer}
        general={word.data.general}
      />
    </div>

    {
      word.data.tags.length > 0 && (
        <ul class="mb-8 flex flex-wrap gap-2">
          {word.data.tags.map((tag) => (
            <li
              title={TAGS[tag].description}
              class:list={[
                "border-2 px-3 py-1 text-xs font-black",
                // タグの色を分野の世界に合わせる。tech=エンジニア緑／daily=ふつうピンク。
                TAGS[tag].world === "tech" ? "bg-engineer" : "bg-general",
              ]}
            >
              #{tag}
            </li>
          ))}
        </ul>
      )
    }

    {
      hasBody && (
        <div class="bg-card border-4 p-5 leading-loose">
          <Content />
        </div>
      )
    }
  </div>
</Layout>

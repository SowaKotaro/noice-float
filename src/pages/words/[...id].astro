---
import { getCollection, render } from "astro:content";
import MeaningCards from "../../components/MeaningCards";
import SiteLogo from "../../components/SiteLogo.astro";
import Layout from "../../layouts/Layout.astro";
import { TAGS } from "../../lib/tags";

export async function getStaticPaths() {
  const words = await getCollection("words");
  return words.map((word) => ({ params: { id: word.id }, props: { word } }));
}

const { word } = Astro.props;
const { Content } = await render(word);
const hasBody = !!word.body?.trim();
---

<Layout title={`${word.data.term} - そのフロート、アイス乗ってません！`}>
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-8">
    <a href="/" class="inline-block" title="一覧へ">
      <SiteLogo
        widths={[240, 480]}
        sizes="240px"
        class="h-auto w-[180px] sm:w-[240px]"
      />
    </a>

    {/* 語名・読みはカードの中にある（GENERAL カードの大見出しが h1）。 */}
    <MeaningCards
      client:load
      term={word.data.term}
      reading={word.data.reading}
      engineer={word.data.engineer}
      general={word.data.general}
    />

    {
      word.data.tags.length > 0 && (
        <ul class="mt-14 flex flex-wrap justify-center gap-2">
          {word.data.tags.map((tag) => (
            <li
              title={TAGS[tag].description}
              class:list={[
                "border-2 border-black px-2 py-0.5 text-xs font-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] sm:text-sm",
                // タグの色を分野の世界に合わせる。tech=青緑／daily=黄。
                TAGS[tag].world === "tech" ? "bg-[#4ECDC4]" : "bg-[#FFD166]",
              ]}
            >
              #{tag}
            </li>
          ))}
        </ul>
      )
    }

    {
      hasBody && (
        <div class="mt-10 border-4 border-black bg-white p-5 leading-loose shadow-[10px_10px_0px_0px_rgba(0,0,0,1)]">
          <Content />
        </div>
      )
    }
  </div>
</Layout>

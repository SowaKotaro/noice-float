---
import { ClientRouter } from "astro:transitions";
import { DEFAULT_LEVEL, STORAGE_KEY } from "../lib/levelize";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "エンジニアと非エンジニアで意味の異なる語を、両方の視点から引ける辞書。",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />
    <script
      is:inline
      define:vars={{ key: STORAGE_KEY, fallback: String(DEFAULT_LEVEL) }}
    >
      // ハイドレーションより前にエンジニア度を反映し、説明文のちらつきを防ぐ。
      const applyStoredLevel = () => {
        document.documentElement.dataset.eng =
          localStorage.getItem(key) ?? fallback;
      };
      applyStoredLevel();
      document.addEventListener("astro:after-swap", applyStoredLevel);
    </script>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
